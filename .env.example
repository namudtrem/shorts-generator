# ---- Supabase ----
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Service role key — SERVER ONLY, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ---- Claude (Anthropic) — story generation ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- ElevenLabs — text to speech ----
ELEVENLABS_API_KEY=...
# A voice ID from your ElevenLabs Voices page. Default below is "Rachel".
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ---- AI images (Replicate / Flux) ----
REPLICATE_API_TOKEN=r8_...
# Image model on Replicate. Flux Schnell is fast + cheap.
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-schnell

# ---- Creatomate — video rendering ----
CREATOMATE_API_KEY=...

# ---- App ----
# Public base URL of the deployed app (used for webhooks). e.g. https://your-site.netlify.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
